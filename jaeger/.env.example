# Jaeger - Distributed Tracing
JAEGER_IMAGE=jaegertracing/all-in-one:1.54
JAEGER_CONTAINER_NAME=jaeger
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_HTTP_PORT=14268
JAEGER_COLLECTOR_GRPC_PORT=14250

# Storage: "memory" (default, ephemeral), "badger" (local disk), "elasticsearch", "cassandra"
JAEGER_STORAGE=memory

# OpenTelemetry Collector
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.93.0
OTEL_COLLECTOR_CONTAINER_NAME=otel-collector
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8888

# Point your app at: http://localhost:4318 (HTTP) or localhost:4317 (gRPC)
# View traces at: http://localhost:16686
