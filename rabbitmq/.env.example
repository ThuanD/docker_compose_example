# RabbitMQ Configuration
RABBITMQ_IMAGE=rabbitmq:3.12-management
RABBITMQ_CONTAINER_NAME=rabbitmq
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
RABBITMQ_VHOST=/
# Generate with: openssl rand -hex 32
RABBITMQ_ERLANG_COOKIE=CHANGE_THIS_TO_RANDOM_COOKIE_64_CHARS
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692

# RabbitMQ Exporter Configuration
RABBITMQ_EXPORTER_IMAGE=kbudde/rabbitmq-exporter:v1.0.0-RC19
RABBITMQ_EXPORTER_CONTAINER_NAME=rabbitmq-exporter
RABBITMQ_EXPORTER_PORT=9419
