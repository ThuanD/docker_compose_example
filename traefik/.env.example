# Traefik Configuration
TRAEFIK_IMAGE=traefik:v3.0
TRAEFIK_CONTAINER_NAME=traefik
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
# Dashboard is bound to 127.0.0.1 only. Set to true for quick local access via http://localhost:8080
# For production, leave as false and configure a secured Router with BasicAuth middleware instead.
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_API_INSECURE=false
TRAEFIK_LOG_LEVEL=INFO

# Let's Encrypt Configuration (required - must be your real email)
ACME_EMAIL=you@example.com

# Demo Service Configuration
WHOAMI_IMAGE=traefik/whoami:v1.10
WHOAMI_CONTAINER_NAME=whoami
