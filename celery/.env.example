# Redis Broker Configuration
REDIS_IMAGE=redis:7.2-alpine
REDIS_CONTAINER_NAME=celery-redis

# Celery Application Image
CELERY_APP_IMAGE=celery-example-app:latest

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
CELERY_WORKER_REPLICAS=2

# Worker/Beat container names
CELERY_WORKER_CONTAINER_NAME=celery-worker
CELERY_BEAT_CONTAINER_NAME=celery-beat

# Flower (monitoring UI)
CELERY_FLOWER_CONTAINER_NAME=celery-flower
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
