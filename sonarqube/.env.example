# SonarQube Configuration
SONARQUBE_IMAGE=sonarqube:10.4.1-community
SONARQUBE_CONTAINER_NAME=sonarqube
SONAR_JDBC_URL=jdbc:postgresql://sonar_db:5432/sonar
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
SONAR_PORT=9000
ENVIRONMENT=development
VERSION=1.0

# PostgreSQL Configuration
SONAR_DB_IMAGE=postgres:15.5-alpine
SONAR_DB_CONTAINER_NAME=sonar_db
POSTGRES_USER=sonar
# Must match SONAR_JDBC_PASSWORD above
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
POSTGRES_DB=sonar
