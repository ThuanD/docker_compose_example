# InfluxDB Configuration
INFLUXDB_IMAGE=influxdb:2.7
INFLUXDB_CONTAINER_NAME=influxdb
INFLUXDB_PORT=8086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
INFLUXDB_ORG=myorg
INFLUXDB_BUCKET=mybucket
# Generate with: openssl rand -hex 32
INFLUXDB_TOKEN=CHANGE_THIS_TO_A_RANDOM_TOKEN_64_CHARS

# Grafana Configuration
GRAFANA_IMAGE=grafana/grafana:10.2.4
GRAFANA_CONTAINER_NAME=influx-grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
GRAFANA_PLUGINS=

# Telegraf Configuration
TELEGRAF_IMAGE=telegraf:1.29-alpine
TELEGRAF_CONTAINER_NAME=telegraf
