# Temporal - Workflow Engine
TEMPORAL_IMAGE=temporalio/auto-setup:1.22.5
TEMPORAL_CONTAINER_NAME=temporal
TEMPORAL_GRPC_PORT=7233

# Temporal Web UI
TEMPORAL_UI_IMAGE=temporalio/ui:2.22.3
TEMPORAL_UI_CONTAINER_NAME=temporal-ui
TEMPORAL_UI_PORT=8080

# PostgreSQL (persistence backend)
POSTGRES_IMAGE=postgres:15.5-alpine
POSTGRES_CONTAINER_NAME=temporal-postgres
POSTGRES_USER=temporal
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
