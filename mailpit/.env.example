# Mailpit - SMTP Testing Server for Development
MAILPIT_IMAGE=axllent/mailpit:v1.14
MAILPIT_CONTAINER_NAME=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Retention
MP_MAX_MESSAGES=5000

# For dev convenience, accept any SMTP auth. Set to 0 in shared/staging environments.
MP_SMTP_AUTH_ACCEPT_ANY=1
MP_SMTP_AUTH_ALLOW_INSECURE=1

# UI basic auth. Format: user:bcrypt_hash (generate with htpasswd).
# Leave empty to disable auth for local dev.
MP_UI_AUTH=

# Configure your app to use: SMTP host=mailpit (or localhost), port=1025
# View captured mail at: http://localhost:8025
