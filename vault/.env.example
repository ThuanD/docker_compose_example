# HashiCorp Vault - Secrets Management
VAULT_IMAGE=hashicorp/vault:1.15
VAULT_CONTAINER_NAME=vault
VAULT_PORT=8200
VAULT_LOG_LEVEL=info

# First-time init (run inside container once Vault is up):
#   docker exec -it vault vault operator init -key-shares=5 -key-threshold=3
# Save the unseal keys and root token. Then unseal with 3 of 5 keys:
#   docker exec -it vault vault operator unseal <key>
#
# UI at: http://localhost:8200
