# LocalStack - AWS Cloud Emulator
LOCALSTACK_IMAGE=localstack/localstack:3.1
LOCALSTACK_CONTAINER_NAME=localstack

# Comma-separated list of AWS services to emulate
LOCALSTACK_SERVICES=s3,sqs,sns,dynamodb,lambda,ses,secretsmanager

# 0 = info, 1 = debug output
LOCALSTACK_DEBUG=0

# 1 = persist state across restarts, 0 = ephemeral
LOCALSTACK_PERSISTENCE=1

# Optional: LocalStack Pro auth token (leave empty for community edition)
LOCALSTACK_AUTH_TOKEN=

# Edge port (single endpoint for all services)
LOCALSTACK_EDGE_PORT=4566
LOCALSTACK_EXTERNAL_PORT_START=4510
LOCALSTACK_EXTERNAL_PORT_END=4559

# Usage (no real AWS credentials needed - any value works):
#   AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test \
#   aws --endpoint-url=http://localhost:4566 s3 ls
