# WordPress Configuration
WORDPRESS_IMAGE=wordpress:6.5-php8.2-apache
WORDPRESS_CONTAINER_NAME=wordpress
WORDPRESS_PORT=8080
WORDPRESS_TABLE_PREFIX=wp_
# Set to 1 only for local development; must be 0 in production
WORDPRESS_DEBUG=0

# MySQL Configuration
MYSQL_IMAGE=mysql:8.2.0
MYSQL_CONTAINER_NAME=wordpress-mysql
MYSQL_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN

# phpMyAdmin Configuration
PHPMYADMIN_IMAGE=phpmyadmin:5.2.1
PHPMYADMIN_CONTAINER_NAME=wordpress-phpmyadmin
PHPMYADMIN_PORT=8081
