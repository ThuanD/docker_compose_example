# Meilisearch - Lightweight Full-Text Search Engine
MEILISEARCH_IMAGE=getmeili/meilisearch:v1.6
MEILISEARCH_CONTAINER_NAME=meilisearch
MEILISEARCH_PORT=7700

# Environment: development (no master key required) or production (master key required)
MEILI_ENV=production

# Generate with: openssl rand -hex 32 (minimum 16 bytes in production)
MEILI_MASTER_KEY=CHANGE_THIS_TO_RANDOM_KEY_MIN_16_BYTES

MEILI_LOG_LEVEL=INFO
MEILI_MAX_INDEXING_MEMORY=1Gb
