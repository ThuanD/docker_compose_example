# MySQL Configuration
MYSQL_IMAGE=mysql:8.2.0
MYSQL_CONTAINER_NAME=mysql
MYSQL_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
MYSQL_DATABASE=mydatabase
MYSQL_USER=myuser
MYSQL_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
MYSQL_PORT=3306

# phpMyAdmin Configuration
PHPMYADMIN_IMAGE=phpmyadmin:5.2.1
PHPMYADMIN_CONTAINER_NAME=phpmyadmin
PHPMYADMIN_PORT=8080
PMA_ARBITRARY=0
UPLOAD_LIMIT=256M
MEMORY_LIMIT=512M

# Backup Configuration
MYSQL_BACKUP_CONTAINER_NAME=mysql-backup
# Backup interval in seconds (default 24h = 86400)
BACKUP_INTERVAL_SECONDS=86400
# Number of days to keep old backups
BACKUP_RETENTION_DAYS=7