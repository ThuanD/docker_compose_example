# Keycloak Configuration
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:23.0.4
KEYCLOAK_CONTAINER_NAME=keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_HTTPS_PORT=8443
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_LOG_LEVEL=INFO
KEYCLOAK_METRICS=true
KEYCLOAK_HEALTH=true
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
# Use `start-dev` for local development, `start --optimized` for production
KEYCLOAK_COMMAND=start-dev

# PostgreSQL Configuration
POSTGRES_IMAGE=postgres:15.5-alpine
POSTGRES_CONTAINER_NAME=keycloak-postgres
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
