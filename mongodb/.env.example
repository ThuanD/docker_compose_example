# MongoDB Configuration
MONGO_IMAGE=mongo:7.0.5
MONGO_CONTAINER_NAME=mongodb
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
MONGO_INITDB_DATABASE=mydatabase
MONGO_PORT=27017

# Mongo Express Configuration
MONGO_EXPRESS_IMAGE=mongo-express:1.0.2
MONGO_EXPRESS_CONTAINER_NAME=mongo-express
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_ENABLE_ADMIN=true

# Backup Configuration
MONGO_BACKUP_CONTAINER_NAME=mongo-backup
# Backup interval in seconds (default 24h = 86400)
BACKUP_INTERVAL_SECONDS=86400
