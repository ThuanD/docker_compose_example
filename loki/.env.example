# Loki - Log Aggregation
LOKI_IMAGE=grafana/loki:2.9.4
LOKI_CONTAINER_NAME=loki
LOKI_PORT=3100

# Promtail - Log Shipper
PROMTAIL_IMAGE=grafana/promtail:2.9.4
PROMTAIL_CONTAINER_NAME=promtail

# Grafana
GRAFANA_IMAGE=grafana/grafana:10.2.4
GRAFANA_CONTAINER_NAME=loki-grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32_CHARS_MIN
